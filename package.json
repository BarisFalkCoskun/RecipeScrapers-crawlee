{
  "name": "recipe-scrapers-crawlee",
  "version": "1.0.0",
  "type": "module",
  "description": "Danish recipe web crawler",
  "scripts": {
    "start": "tsx src/main.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:all": "mkdir -p logs && { npm run build && npm test && npm run smoke:crawl; } 2>&1 | tee \"logs/test-run-$(date +%Y%m%d-%H%M%S).txt\"",
    "test:watch": "vitest",
    "report:runs": "tsx src/scripts/report-crawl-runs.ts",
    "smoke:crawl": "node --import tsx/esm src/scripts/smoke-crawl.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "crawlee": "^3.16.0",
    "dotenv": "^17.3.1",
    "mongodb": "^7.1.1",
    "node-object-hash": "^3.1.1",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
